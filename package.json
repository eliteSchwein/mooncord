{
  "name": "mooncord",
  "version": "1.3.1",
  "description": "Moonraker Discord Bot based on Discord.js",
  "main": "index.js",
  "scripts": {
    "migrateJson": "node src/migration/ConfigMigration.js",
    "start": "node --max-old-space-size=92 --expose-gc --gc-global dist/index.js",
    "debugstart": "node --inspect=0.0.0.0:3000 --max-old-space-size=92 --trace_gc --expose-gc --trace-deprecation --trace-warnings --trace-uncaught --track-heap-objects --gc-global dist/index.js",
    "checkcodestyle": "npx eslint ./**",
    "autofixcodestyle": "npx eslint ./** --fix",
    "ncu": "ncu",
    "generatelocale": "node src/helper/LocaleGenerationHelper.js",
    "build": "node build.mjs",
    "build:dev": "node build.mjs dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eliteSchwein/mooncord.git"
  },
  "keywords": [],
  "author": "eliteSCHW31N",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/eliteSchwein/mooncord/issues"
  },
  "homepage": "https://github.com/eliteSchwein/mooncord#readme",
  "devDependencies": {
    "@discordjs/rest": "^2.6.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/gm": "^1.25.4",
    "@types/node": "^25.2.3",
    "@types/readline-sync": "^1.4.8",
    "async-wait-until": "2.0.31",
    "axios": "^1.13.5",
    "bytes": "^3.1.2",
    "colorts": "^0.1.63",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "gm": "^1.25.1",
    "jimp": "^1.6.0",
    "js-conf-parser": "^1.0.3",
    "lodash": "^4.17.23",
    "node-fetch": "^3.3.2",
    "npm-check-updates": "^19.3.2",
    "readline-sync": "^1.4.10",
    "regex-parser": "^2.3.1",
    "stacktrace-js": "^2.0.2",
    "typescript": "^5.9.3",
    "websocket-ts": "^2.2.1",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "discord.js": "^14.25.1",
    "sharp": "^0.34.5"
  }
}
